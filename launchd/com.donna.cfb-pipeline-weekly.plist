        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
        <key>Weekday</key>
        <integer>1</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/palmerjonesadmin/cfb-recruiting-pipeline</string>

    <key>EnvironmentVariables</key>
